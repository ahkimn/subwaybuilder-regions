{
  "devDependencies": {
    "@terraformer/arcgis": "^2.1.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.8",
    "@types/fs-extra": "^11.0.4",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.0.10",
    "@types/osmtogeojson": "^2.2.34",
    "@types/polylabel": "^1.1.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/terraformer__arcgis": "^2.0.5",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jsdom": "^26.1.0",
    "osmtogeojson": "^3.0.0-beta.5",
    "polylabel": "^2.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.1",
    "@turf/turf": "^7.3.3",
    "adm-zip": "^0.5.17",
    "csv-parse": "^6.1.0",
    "dbffile": "^1.12.0",
    "fs-extra": "^11.3.3",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "maplibre-gl": "^5.16.0",
    "minimist": "^1.2.8",
    "path": "^0.12.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "tsx": "^4.21.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "name": "subwaybuilder-regions",
  "version": "0.4.8",
  "description": "Monorepo for SubwayBuilder mods with shared core library.",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:regions && npm run build:enhanced-demand-view",
    "build:regions": "vite build -c mods/regions/vite.config.ts  && npm run build:fetch-cli",
    "build:enhanced-demand-view": "vite build -c mods/enhanced-demand-view/vite.config.ts",
    "build:fetch-cli": "tsx scripts/build/build-fetch-cli.ts",
    "build:dev": "npm run build:regions && npm run link:regions && npm run dev",
    "build:dev:enhanced-demand-view": "npm run build:enhanced-demand-view && npm run link:enhanced-demand-view && npm run dev",
    "dev": "tsx scripts/dev.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "symlink": "tsx scripts/link.ts --mod=all",
    "symlink:regions": "tsx scripts/link.ts --mod=regions",
    "symlink:enhanced-demand-view": "tsx scripts/link.ts --mod=enhanced-demand-view",
    "link:jp-data": "tsx scripts/link-jp-data.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"lib/**/*.{ts,tsx}\" \"mods/**/*.{ts,tsx}\" \"scripts/**/*.ts\" \"test/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "serve": "npm run serve:regions",
    "serve:regions": "tsx scripts/serve-data.ts",
    "extract:map-features": "tsx scripts/extract-map-features.ts",
    "fetch:city": "tsx scripts/fetch-city-datasets.ts",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"test/**/*.test.ts\"",
    "export": "tsx scripts/export-data-archives.ts",
    "release:regions:version": "tsx scripts/build/resolve-release-version.ts --changelog=docs/regions/CHANGELOG.md",
    "release:regions:package": "npm run build:regions && npm run build:fetch-cli && tsx scripts/build/package-release.ts --mod=regions",
    "release:enhanced-demand-view:version": "tsx scripts/build/resolve-release-version.ts --changelog=docs/enhanced-demand-view/CHANGELOG.md",
    "release:enhanced-demand-view:package": "npm run build:enhanced-demand-view && tsx scripts/build/package-release.ts --mod=enhanced-demand-view"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahkimn/subwaybuilder-regions.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ahkimn/subwaybuilder-regions/issues"
  }
}